### TalentBridge API — REST Client Test Suite
### Order: Register → Login → Use token for all protected endpoints

@host = http://localhost:5257
@candidateToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Y_ZWIYzvT6h39lMBE0oW48GkI812IB25Hth5EYRBR6o
@recruiterToken = <replace-after-login>

##############################################################################
# AUTH ENDPOINTS
##############################################################################

### 1. Register as a Candidate
# @name registerCandidate
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Test Candidate",
  "email": "test.candidate@mail.com",
  "password": "Candidate@123",
  "role": "Candidate"
}

###

### 2. Register as a Recruiter
# @name registerRecruiter
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Test Recruiter",
  "email": "test.recruiter@acme.com",
  "password": "Recruiter@123",
  "role": "Recruiter"
}

###

### 3. Login as Candidate — copy AccessToken from response into candidateToken above
# @name loginCandidate
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "candidate1@mail.com",
  "password": "Candidate@123"
}

###

### 4. Login as Recruiter — copy AccessToken into recruiterToken above
# @name loginRecruiter
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "recruiter1@acmecorp.com",
  "password": "Recruiter@123"
}

###

### 5. Login as Admin
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@talentbridge.com",
  "password": "Admin@123"
}

###

### 6. Try login with wrong password (expect 401)
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "candidate1@mail.com",
  "password": "WrongPassword!"
}

###

### 7. Try to register with invalid role (expect 400)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Bad Actor",
  "email": "bad@mail.com",
  "password": "Bad@123456",
  "role": "Admin"
}

###

### 8. Get current user info (requires candidateToken)
GET {{host}}/api/auth/me
Authorization: Bearer {{candidateToken}}

###

### 9. Get current user info (requires recruiterToken)
GET {{host}}/api/auth/me
Authorization: Bearer {{recruiterToken}}

###

### 10. Access protected endpoint without token (expect 401)
GET {{host}}/api/auth/me

###

##############################################################################
# LOGOUT ENDPOINTS
##############################################################################

### 11. Logout (invalidates the token server-side)
POST {{host}}/api/auth/logout
Authorization: Bearer {{candidateToken}}

###

##############################################################################
# JOBS ENDPOINTS
##############################################################################

### 14. List all open jobs (no filter)
GET {{host}}/api/jobs

###

### 15. List jobs with keyword filter
GET {{host}}/api/jobs?keyword=developer

###

### 16. Filter by location
GET {{host}}/api/jobs?location=remote

###

### 17. Filter by job type
GET {{host}}/api/jobs?jobType=Remote

###

### 18. Filter by salary range
GET {{host}}/api/jobs?salaryMin=80000&salaryMax=140000

###

### 19. Filter by skill IDs (skill 1 = C#, skill 8 = SQL)
GET {{host}}/api/jobs?skillIds=1&skillIds=8

###

### 20. Combined filter + pagination (page 1, 2 results)
GET {{host}}/api/jobs?location=usa&jobType=FullTime&page=1&pageSize=2

###

### 21. Get job details by ID
GET {{host}}/api/jobs/1

###

### 22. Get job that doesn't exist (expect 404)
GET {{host}}/api/jobs/9999

###

### 23. Create a new job [Recruiter]
# First set @recruiterToken by running request #4 (login as recruiter)
POST {{host}}/api/jobs
Authorization: Bearer {{recruiterToken}}
Content-Type: application/json

{
  "title": "Full Stack Developer",
  "description": "We are looking for a skilled Full Stack Developer to join our team. You will work on both backend APIs and frontend UIs.",
  "location": "Remote",
  "jobType": "FullTime",
  "salaryMin": 75000,
  "salaryMax": 110000,
  "experienceLevel": "Mid",
  "expiresAt": "2026-06-01T00:00:00Z",
  "requiredSkillIds": [1, 3],
  "optionalSkillIds": [5, 8]
}

###

### 24. Create a job as Candidate (expect 403)
POST {{host}}/api/jobs
Authorization: Bearer {{candidateToken}}
Content-Type: application/json

{
  "title": "Sneaky Job",
  "description": "Should not be allowed",
  "location": "Nowhere",
  "jobType": "FullTime",
  "salaryMin": 50000,
  "salaryMax": 70000,
  "requiredSkillIds": [],
  "optionalSkillIds": []
}

###

### 25. Update a job (change status to Closed) [Recruiter]
PUT {{host}}/api/jobs/1
Authorization: Bearer {{recruiterToken}}
Content-Type: application/json

{
  "status": "Closed",
  "salaryMin": 95000,
  "salaryMax": 135000
}

###

### 26. Update job title and add new skills [Recruiter]
PUT {{host}}/api/jobs/2
Authorization: Bearer {{recruiterToken}}
Content-Type: application/json

{
  "title": "Senior React Developer",
  "requiredSkillIds": [5, 4],
  "optionalSkillIds": [3]
}

###

### 27. Get applicants for job 1 [Recruiter] (sorted by match score)
GET {{host}}/api/jobs/1/applicants
Authorization: Bearer {{recruiterToken}}

###

### 28. Get applicants filtered by status [Recruiter]
GET {{host}}/api/jobs/1/applicants?status=Shortlisted
Authorization: Bearer {{recruiterToken}}

###

### 29. Get applicants filtered by min experience + skill [Recruiter]
GET {{host}}/api/jobs/1/applicants?minExperience=3&skillIds=1
Authorization: Bearer {{recruiterToken}}

###

### 30. Get applicants for a job you don't own (expect 403)
GET {{host}}/api/jobs/3/applicants
Authorization: Bearer {{recruiterToken}}

###

### 31. Delete a job [Recruiter]
# (run this last so we don't lose data; change ID 6 to the job created in request 23)
DELETE {{host}}/api/jobs/6
Authorization: Bearer {{recruiterToken}}

###
